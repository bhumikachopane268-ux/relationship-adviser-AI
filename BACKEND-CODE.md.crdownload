## 6️⃣ Assessments CRUD
**File:** `src/app/api/assessments/route.ts`

```typescript
import { NextRequest, NextResponse } from 'next/server'
import { jwtVerify } from 'jose'
import { db } from '@/lib/db'

const JWT_SECRET = new TextEncoder().encode(
  process.env.JWT_SECRET || 'your-secret-key-min-32-characters'
)

// GET - Get all assessments for current user
export async function GET(request: NextRequest) {
  try {
    const authHeader = request.headers.get('authorization')
    let token = authHeader?.startsWith('Bearer ')
      ? authHeader.slice(7)
      : null

    if (!token) {
      token = request.cookies.get('token')?.value
    }

    if (!token) {
      return NextResponse.json(
        { error: 'Not authenticated' },
        { status: 401 }
      )
    }

    const { payload } = await jwtVerify(token, JWT_SECRET)
    const userId = payload.userId as string

    const assessments = await db.assessment.findMany({
      where: { userId },
      orderBy: { createdAt: 'desc' },
      take: 20
    })

    return NextResponse.json({ assessments })
  } catch (error) {
    console.error('Error fetching assessments:', error)
    return NextResponse.json(
      { error: 'Failed to fetch assessments' },
      { status: 500 }
    )
  }
}

// POST - Create new assessment
export async function POST(request: NextRequest) {
  try {
    const authHeader = request.headers.get('authorization')
    let token = authHeader?.startsWith('Bearer ')
      ? authHeader.slice(7)
      : null

    if (!token) {
      token = request.cookies.get('token')?.value
    }

    if (!token) {
      return NextResponse.json(
        { error: 'Not authenticated' },
        { status: 401 }
      )
    }

    const { payload } = await jwtVerify(token, JWT_SECRET)
    const userId = payload.userId as string

    const { partnerAAnswers, partnerBAnswers, analysisResult } = await request.json()

    // Extract scores from AI response
    const extractScore = (text: string, scoreName: string) => {
      const match = text.match(new RegExp(`${scoreName}:\\s*(\\d+)/100`, 'i'))
      return match ? parseFloat(match[1]) : null
    }

    const overallScore = extractScore(analysisResult, 'Overall Compatibility Score')
    const communicationScore = extractScore(analysisResult, 'Communication Score')
    const trustScore = extractScore(analysisResult, 'Trust Score')
    const emotionalScore = extractScore(analysisResult, 'Emotional Connection Score')
    const goalScore = extractScore(analysisResult, 'Goal Alignment Score')
    const conflictScore = extractScore(analysisResult, 'Conflict Management Score')

    // Create assessment in database
    const assessment = await db.assessment.create({
      data: {
        userId,
        partnerAAnswers: JSON.stringify(partnerAAnswers),
        partnerBAnswers: JSON.stringify(partnerBAnswers),
        analysisResult: JSON.stringify({ analysisResult }),
        overallScore,
        communicationScore,
        trustScore,
        emotionalScore,
        goalScore,
        conflictScore
      }
    })

    return NextResponse.json({ assessment })
  } catch (error) {
    console.error('Error creating assessment:', error)
    return NextResponse.json(
      { error: 'Failed to create assessment' },
      { status: 500 }
    )
  }
}
```

