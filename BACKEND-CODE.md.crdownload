## 5️⃣ AI Relationship Analysis
**File:** `src/app/api/analyze-relationship/route.ts`

```typescript
import { NextRequest, NextResponse } from 'next/server'
import { jwtVerify } from 'jose'
import ZAI from 'z-ai-web-dev-sdk'

const JWT_SECRET = new TextEncoder().encode(
  process.env.JWT_SECRET || 'your-secret-key-min-32-characters'
)

export async function POST(request: NextRequest) {
  try {
    // Get token from Authorization header
    const authHeader = request.headers.get('authorization')
    let token = authHeader?.startsWith('Bearer ')
      ? authHeader.slice(7)
      : null

    // Fall back to cookie
    if (!token) {
      token = request.cookies.get('token')?.value
    }

    if (!token) {
      return NextResponse.json(
        { error: 'Not authenticated' },
        { status: 401 }
      )
    }

    // Verify token
    await jwtVerify(token, JWT_SECRET)

    const { partnerAAnswers, partnerBAnswers } = await request.json()

    // Format answers for AI
    const formatAnswers = (answers: Record<string, string>) => {
      return Object.entries(answers)
        .map(([questionId, answer]) => {
          const question = questionId.replace(/_/g, ' ')
            .replace(/([A-Z])/g, ' $1')
            .trim()
            .replace(/^\w/, c => c.toUpperCase())
          return `${question}: ${answer}`
        })
        .join('\n')
    }

    const partnerAFormatted = formatAnswers(partnerAAnswers)
    const partnerBFormatted = formatAnswers(partnerBAnswers)

    // System prompt for AI
    const systemPrompt = `You are a professional Relationship Counselor AI.

TASKS:
1. Analyze both partners independently
2. Compare both perspectives
3. Identify communication, trust, emotional compatibility
4. Calculate scores (Communication, Trust, Emotional, Goals, Conflict, Overall)
5. Provide strengths, challenges, recommendations
6. Create 30-Day Improvement Plan

OUTPUT FORMAT:
Overall Compatibility Score: X/100
Communication Score: X/100
Trust Score: X/100
Emotional Connection Score: X/100
Goal Alignment Score: X/100
Conflict Management Score: X/100

Strengths:
• ...

Challenges:
• ...

Recommendations:
...

30-Day Action Plan:
Week 1: ...
Week 2: ...
Week 3: ...
Week 4: ...`

    const userPrompt = `Partner A Responses:
${partnerAFormatted}

Partner B Responses:
${partnerBFormatted}

Please analyze both partners' responses and generate a comprehensive relationship analysis report following the specified format.`

    // Call AI
    const zai = await ZAI.create()

    const completion = await zai.chat.completions.create({
      messages: [
        {
          role: 'assistant',
          content: systemPrompt
        },
        {
          role: 'user',
          content: userPrompt
        }
      ],
      thinking: { type: 'disabled' }
    })

    const messageContent = completion.choices[0]?.message?.content

    if (!messageContent) {
      throw new Error('No response from AI')
    }

    return NextResponse.json({ result: messageContent })
  } catch (error) {
    console.error('Error analyzing relationship:', error)
    return NextResponse.json(
      { error: 'Failed to analyze relationship' },
      { status: 500 }
    )
  }
}
```

